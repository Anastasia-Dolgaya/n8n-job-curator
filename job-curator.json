    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) {\n  return [{ json: { skip: true, html: '' } }];\n}\n\nconst rows = items.map(item => {\n  const score = item.json.fit_score || '?';\n  const title = item.json.original_title || item.json.title || 'Unknown';\n  const link = item.json.original_link || item.json.link || '#';\n  const reason = item.json.reason || '';\n  const flags = (item.json.red_flags || []).join(', ');\n  \n  return `\n    <tr>\n      <td style=\"padding:8px;border-bottom:1px solid #eee;\">\n        <a href=\"${link}\" style=\"font-weight:bold;color:#1a73e8;\">${title}</a>\n      </td>\n      <td style=\"padding:8px;border-bottom:1px solid #eee;text-align:center;\">\n        <strong>${score}/10</strong>\n      </td>\n      <td style=\"padding:8px;border-bottom:1px solid #eee;\">${reason}</td>\n      <td style=\"padding:8px;border-bottom:1px solid #eee;color:#d93025;font-size:12px;\">${flags}</td>\n    </tr>\n  `;\n}).join('');\n\nconst html = `\n  <html><body style=\"font-family:Arial,sans-serif;max-width:900px;margin:0 auto;\">\n    <h2 style=\"color:#1a73e8;\">Job Curator — Daily Digest</h2>\n    <p style=\"color:#666;\">${new Date().toLocaleDateString('en-GB')} · ${items.length} relevant job${items.length > 1 ? 's' : ''} found</p>\n    <table style=\"width:100%;border-collapse:collapse;\">\n      <thead>\n        <tr style=\"background:#f8f9fa;\">\n          <th style=\"padding:8px;text-align:left;\">Role</th>\n          <th style=\"padding:8px;text-align:center;\">Score</th>\n          <th style=\"padding:8px;text-align:left;\">Why</th>\n          <th style=\"padding:8px;text-align:left;\">Red Flags</th>\n        </tr>\n      </thead>\n      <tbody>${rows}</tbody>\n    </table>\n    <p style=\"color:#999;font-size:12px;margin-top:20px;\">Powered by Job Curator · n8n + Claude API</p>\n  </body></html>\n`;\n\nreturn [{ json: { html, count: items.length, skip: false } }];"
      },
