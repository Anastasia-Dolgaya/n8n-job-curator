              "id": "93f52a66-5e66-4bdc-850e-7998f37c1b6d",
              "name": "prompt",
              "value": "==You are evaluating job postings against a candidate's criteria. Return structured JSON.\n\nCANDIDATE CRITERIA:\n{{ $json.criteria }}\n\nJOB POSTING:\nJob ID: {{ $('Code: Dedup Seen in Sheet').item.json.link }}\nTitle: {{ $('Code: Dedup Seen in Sheet').item.json.title }}\n\nDescription: {{ ($('Code: Dedup Seen in Sheet').item.json.content || $('Code: Dedup Seen in Sheet').item.json.contentSnippet || '').replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').substring(0, 2000) }}\n\nReturn ONLY valid JSON, no markdown:\n{\n  \"relevant\": true | false,\n  \"fit_score\": 1-10,\n  \"category\": \"string matching one of the categories from criteria\",\n  \"reason\": \"one sentence explaining the score\",\n  \"red_flags\": [\"specific issues from the candidate's criteria\"],\n  \"job_id\": \"copy the Job ID from input exactly as provided\"\n}",
              "type": "string"
            },
